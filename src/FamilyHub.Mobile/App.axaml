<Application xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="FamilyHub.Mobile.App">
  <Application.Styles>
    <FluentTheme />
    <Style Selector="Button"><Setter Property="MinHeight" Value="52"/><Setter Property="CornerRadius" Value="26"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Padding" Value="20,10"/></Style>
    <Style Selector="Button.primary"><Setter Property="Background" Value="#6750A4"/><Setter Property="Foreground" Value="White"/></Style>
    <Style Selector="Border.card"><Setter Property="CornerRadius" Value="28"/><Setter Property="Padding" Value="20"/><Setter Property="Background" Value="#F1ECF4"/></Style>
    <Style Selector="TextBlock.title"><Setter Property="FontSize" Value="32"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Foreground" Value="#201A23"/></Style>
    <Style Selector="TextBlock.label"><Setter Property="FontSize" Value="13"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="#6750A4"/></Style>
    <Style Selector="TextBox"><Setter Property="MinHeight" Value="52"/><Setter Property="CornerRadius" Value="16"/></Style>
  </Application.Styles>
</Application>
