<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="using:FamilyHub.Mobile.ViewModels" x:Class="FamilyHub.Mobile.Views.MainView" x:DataType="vm:MainViewModel" Background="#FFFBFE">
  <Grid RowDefinitions="Auto,*,Auto" Margin="20,24,20,16">
    <Grid ColumnDefinitions="*,Auto"><StackPanel><TextBlock Classes="label" Text="FAMILYHUB"/><TextBlock Classes="title" Text="Calendar remote"/></StackPanel><Border Grid.Column="1" CornerRadius="22" Background="#EADDFF" Padding="16,9" VerticalAlignment="Center"><TextBlock Text="●  Home" Foreground="#4F378B" FontWeight="SemiBold"/></Border></Grid>
    <ScrollViewer Grid.Row="1" Margin="0,24,0,12">
      <Panel>
        <StackPanel IsVisible="{Binding IsRemote}" Spacing="16">
          <Border Classes="card" Background="#EADDFF"><StackPanel Spacing="10"><TextBlock Classes="label" Text="NOW SHOWING"/><TextBlock Text="{Binding CurrentScreen}" FontSize="38" FontWeight="Bold"/><TextBlock Text="Tap a view to change the Pi instantly." FontSize="16"/></StackPanel></Border>
          <UniformGrid Columns="2" Rows="3" ColumnSpacing="12" RowSpacing="12"><Button Classes="primary" Content="Today" Command="{Binding ShowScreenCommand}" CommandParameter="Daily"/><Button Content="Week" Command="{Binding ShowScreenCommand}" CommandParameter="Weekly"/><Button Content="Month" Command="{Binding ShowScreenCommand}" CommandParameter="Monthly"/><Button Content="Weather" Command="{Binding ShowScreenCommand}" CommandParameter="Weather"/><Button Content="Agenda" Command="{Binding ShowScreenCommand}" CommandParameter="Agenda"/><Button Content="Family" Command="{Binding ShowScreenCommand}" CommandParameter="Family"/></UniformGrid>
          <Border Classes="card" Background="#D7F8E5"><StackPanel Spacing="8"><TextBlock Classes="label" Text="LIVE CONNECTION"/><TextBlock Text="{Binding Status}" TextWrapping="Wrap"/><Button Content="Refresh connection" Command="{Binding ConnectCommand}" HorizontalAlignment="Left"/></StackPanel></Border>
        </StackPanel>
        <StackPanel IsVisible="{Binding IsCalendar}" Spacing="16">
          <Grid ColumnDefinitions="Auto,*,Auto"><Button Content="‹" Command="{Binding PreviousMonthCommand}"/><TextBlock Grid.Column="1" Classes="title" Text="{Binding MobileMonthTitle}" HorizontalAlignment="Center" VerticalAlignment="Center"/><Button Grid.Column="2" Content="›" Command="{Binding NextMonthCommand}"/></Grid>
          <Border Classes="card" Padding="10"><StackPanel Spacing="4"><UniformGrid Columns="7"><TextBlock Text="SUN" HorizontalAlignment="Center" Classes="label"/><TextBlock Text="MON" HorizontalAlignment="Center" Classes="label"/><TextBlock Text="TUE" HorizontalAlignment="Center" Classes="label"/><TextBlock Text="WED" HorizontalAlignment="Center" Classes="label"/><TextBlock Text="THU" HorizontalAlignment="Center" Classes="label"/><TextBlock Text="FRI" HorizontalAlignment="Center" Classes="label"/><TextBlock Text="SAT" HorizontalAlignment="Center" Classes="label"/></UniformGrid><ItemsControl ItemsSource="{Binding CalendarDays}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="7" Rows="6"/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:MobileCalendarDay"><Button Command="{Binding $parent[UserControl].DataContext.SelectDateCommand}" CommandParameter="{Binding}" Background="{Binding Background}" Foreground="{Binding Foreground}" MinWidth="44" MinHeight="44" Padding="2" Margin="1" Content="{Binding DayNumber}"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></Border>
          <TextBlock Classes="title" FontSize="26" Text="Add an event"/><TextBlock Text="{Binding SelectedDateText}" Foreground="#6750A4" FontWeight="Bold"/>
          <TextBlock Classes="label" Text="EVENT TITLE"/><TextBox Text="{Binding EventTitle}" PlaceholderText="Dentist appointment"/>
          <Grid ColumnDefinitions="*,*" ColumnSpacing="10"><StackPanel><TextBlock Classes="label" Text="START TIME"/><TextBox Text="{Binding EventStartTime}"/></StackPanel><StackPanel Grid.Column="1"><TextBlock Classes="label" Text="END TIME"/><TextBox Text="{Binding EventEndTime}"/></StackPanel></Grid>
          <TextBlock Classes="label" Text="FAMILY MEMBER"/><TextBox Text="{Binding EventPerson}" PlaceholderText="Dad, Xander, Jada…"/>
          <TextBlock Classes="label" Text="LOCATION"/><TextBox Text="{Binding EventLocation}" PlaceholderText="Optional"/>
          <Border Classes="card"><StackPanel><TextBlock Text="Ready to save" FontSize="22" FontWeight="Bold"/><TextBlock Text="The selected date and times will be sent directly to FamilyHub." Margin="0,4,0,12" TextWrapping="Wrap"/><Button Classes="primary" Content="Add to FamilyHub" Command="{Binding AddEventCommand}"/></StackPanel></Border>
          <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Foreground="#6750A4"/><Button Content="Check Google Calendar connection" Command="{Binding CheckGoogleCommand}"/>
        </StackPanel>
        <StackPanel IsVisible="{Binding IsWeather}" Spacing="14">
          <Border Classes="card" Background="#BCE7FA"><Grid ColumnDefinitions="*,Auto"><StackPanel><TextBlock Classes="label" Text="{Binding MobileLocationName}"/><TextBlock Text="{Binding MobileTemperature}" FontSize="58" FontWeight="Bold"/><TextBlock Text="{Binding MobileWeatherCondition}" FontSize="18"/><TextBlock Text="{Binding MobileFeelsLike}"/></StackPanel><TextBlock Grid.Column="1" Text="{Binding MobileWeatherIcon}" FontSize="76" Foreground="#FFB000" VerticalAlignment="Center"/></Grid></Border>
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8"><TextBox Text="{Binding MobileLocationQuery}" PlaceholderText="City, state, or ZIP"/><Button Grid.Column="1" Classes="primary" Content="Use location" Command="{Binding ApplyMobileLocationCommand}"/></Grid>
          <TextBlock Classes="title" Text="7-day forecast"/>
          <ItemsControl ItemsSource="{Binding Forecast}"><ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:MobileForecastDay"><Border Classes="card" Margin="0,0,0,8" Padding="14"><Grid ColumnDefinitions="60,32,*,Auto"><StackPanel><TextBlock Text="{Binding Day}" FontWeight="Bold"/><TextBlock Text="{Binding Date}" FontSize="11"/></StackPanel><TextBlock Grid.Column="1" Text="{Binding Icon}" FontSize="22" VerticalAlignment="Center"/><StackPanel Grid.Column="2"><TextBlock Text="{Binding Condition}"/><TextBlock Text="{Binding RainChance, StringFormat='Rain {0}%'}" Foreground="#6750A4"/></StackPanel><StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Text="{Binding High, StringFormat='{}{0}°'}" FontSize="25"/><TextBlock Text="{Binding Low, StringFormat=' / {0}°'}" FontSize="15" VerticalAlignment="Center" Opacity="0.7"/></StackPanel></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
        </StackPanel>
        <StackPanel IsVisible="{Binding IsFamily}" Spacing="14"><TextBlock Classes="title" Text="Family"/><TextBlock Text="Profiles and colors are shared with the Pi."/><ItemsControl ItemsSource="{Binding People}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:MobilePerson"><Border Classes="card" Width="150" Margin="0,0,10,10"><StackPanel><Border Width="48" Height="48" CornerRadius="24" Background="{Binding Color}" HorizontalAlignment="Left"><TextBlock Text="{Binding Initials}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Text="{Binding Name}" FontSize="19" FontWeight="Bold" Margin="0,8,0,0"/></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel>
        <StackPanel IsVisible="{Binding IsSettings}" Spacing="16">
          <TextBlock Classes="title" Text="Settings"/><TextBlock Classes="label" Text="PI ADDRESS"/><TextBox Text="{Binding PiAddress}"/><Button Content="Connect" Command="{Binding ConnectCommand}"/>
          <Border Classes="card" Background="#FFE2DC"><StackPanel Spacing="12"><TextBlock Text="Screen rotation" FontSize="24" FontWeight="Bold"/><TextBlock Text="Seconds between screen changes (15–3600)" TextWrapping="Wrap"/><TextBox Text="{Binding RotationSeconds}"/><CheckBox Content="Automatically rotate screens" IsChecked="{Binding RotationEnabled}"/><Button Classes="primary" Content="Save timer" Command="{Binding SaveSettingsCommand}"/></StackPanel></Border>
          <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Foreground="#6750A4"/>
        </StackPanel>
      </Panel>
    </ScrollViewer>
    <Border Grid.Row="2" Background="#F3EDF7" CornerRadius="30" Padding="8"><UniformGrid Columns="5" ColumnSpacing="4"><Button Content="Remote" FontSize="11" Command="{Binding SelectTabCommand}" CommandParameter="Remote"/><Button Content="Calendar" FontSize="11" Command="{Binding SelectTabCommand}" CommandParameter="Calendar"/><Button Content="Weather" FontSize="11" Command="{Binding SelectTabCommand}" CommandParameter="Weather"/><Button Content="Family" FontSize="11" Command="{Binding SelectTabCommand}" CommandParameter="Family"/><Button Content="Settings" FontSize="11" Command="{Binding SelectTabCommand}" CommandParameter="Settings"/></UniformGrid></Border>
  </Grid>
</UserControl>
