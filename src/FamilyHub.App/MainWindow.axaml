<Window xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="using:FamilyHub.App.ViewModels" xmlns:inf="using:FamilyHub.Infrastructure" x:Class="FamilyHub.App.MainWindow" x:DataType="vm:MainWindowViewModel" WindowDecorations="None" WindowState="FullScreen" Background="{DynamicResource AppBackground}" KeyDown="OnKeyDown" PointerPressed="OnPointerPressed" PointerWheelChanged="OnPointerWheelChanged">
  <Grid ColumnDefinitions="178,*" RowDefinitions="82,*">
    <Border Grid.RowSpan="2" Background="{DynamicResource SidebarBrush}" BorderBrush="#EFE9E2" BorderThickness="0,0,1,0">
      <Grid RowDefinitions="84,*,Auto" Margin="14,18">
        <Border Width="50" Height="50" CornerRadius="16" Background="#FF5C60" HorizontalAlignment="Left"><TextBlock Text="▣" FontSize="27" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
        <StackPanel Grid.Row="1" Spacing="5">
          <Button Classes="side" Content="▣   Calendar" Command="{Binding NavigateCommand}" CommandParameter="Monthly"/>
          <Button Classes="side" Content="☷   Agenda" Command="{Binding NavigateCommand}" CommandParameter="Agenda"/>
          <Button Classes="side" Content="☑   Today" Command="{Binding NavigateCommand}" CommandParameter="Daily"/>
          <Button Classes="side" Content="▤   Week" Command="{Binding NavigateCommand}" CommandParameter="Weekly"/>
          <Button Classes="side" Content="☀   Weather" Command="{Binding NavigateCommand}" CommandParameter="Weather"/>
          <Button Classes="side" Content="⌁   Family" Command="{Binding NavigateCommand}" CommandParameter="Family"/>
          <Button Classes="side" Content="⏱   Class Block" Command="{Binding NavigateCommand}" CommandParameter="ClassBlock"/>
          <Button Classes="side" Content="▦   News" Command="{Binding NavigateCommand}" CommandParameter="News"/>
          <Button Classes="side" Content="⚙   Settings" Margin="0,28,0,0" Command="{Binding NavigateCommand}" CommandParameter="Settings"/>
        </StackPanel>
        <Border Grid.Row="2" Classes="card" Padding="12" BoxShadow="none"><Grid ColumnDefinitions="Auto,*"><TextBlock Text="{Binding CurrentIcon}" FontSize="31" Foreground="#FFB000"/><StackPanel Grid.Column="1" Margin="8,0"><TextBlock Text="{Binding CurrentTemperatureText}" FontWeight="Bold" Foreground="#092354"/><TextBlock Text="{Binding CurrentLocationName}" FontSize="11" Classes="muted" TextTrimming="CharacterEllipsis"/></StackPanel></Grid></Border>
      </Grid>
    </Border>

    <Grid Grid.Column="1" ColumnDefinitions="54,54,76,*,290,88,118" Margin="24,18,26,12" ColumnSpacing="10">
      <Button Classes="nav top" Content="‹" Command="{Binding PreviousCommand}"/><Button Grid.Column="1" Classes="nav top" Content="›" Command="{Binding NextCommand}"/>
      <Button Grid.Column="2" Classes="nav top" Content="Today" Command="{Binding HomeCommand}"/>
      <Border Grid.Column="4" Height="46" Background="White" BorderBrush="#E4DED7" BorderThickness="1" CornerRadius="14" Padding="14,0"><Grid ColumnDefinitions="Auto,*"><TextBlock Text="⌕" FontSize="24" Foreground="#092354" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding SearchText}" PlaceholderText="Search" BorderThickness="0" Background="Transparent"/></Grid></Border>
      <Button Grid.Column="5" Classes="nav top" Content="Filters" Command="{Binding ToggleFiltersCommand}"/><Button Grid.Column="6" Classes="coral top" Content="New event" Command="{Binding OpenEventEditorCommand}"/>
    </Grid>

    <Panel Grid.Column="1" Grid.Row="1" Margin="24,4,26,24">
      <!-- CURRENT MONTH: generated from the system date, Sunday first, always 42 cells -->
      <Grid IsVisible="{Binding IsMonthly}" RowDefinitions="72,44,*" PointerWheelChanged="OnCalendarWheelChanged">
        <Grid ColumnDefinitions="*,Auto"><StackPanel Orientation="Horizontal" Spacing="10"><Button Classes="nav" Content="‹" Command="{Binding PreviousMonthCommand}"/><TextBlock Classes="heading" Text="{Binding MonthTitle}"/><Button Classes="nav" Content="›" Command="{Binding NextMonthCommand}"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="Today" Command="{Binding CurrentMonthCommand}"/><Button Content="Day" Command="{Binding NavigateCommand}" CommandParameter="Daily"/><Button Content="Week" Command="{Binding NavigateCommand}" CommandParameter="Weekly"/><Button Classes="coral" Content="Month"/></StackPanel></Grid>
        <Border Grid.Row="1" Classes="card" Padding="0"><UniformGrid Columns="7"><Border BorderBrush="#E2DBD4" BorderThickness="0,0,1,0"><TextBlock Text="Sunday" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/></Border><Border BorderBrush="#E2DBD4" BorderThickness="0,0,1,0"><TextBlock Text="Monday" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/></Border><Border BorderBrush="#E2DBD4" BorderThickness="0,0,1,0"><TextBlock Text="Tuesday" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/></Border><Border BorderBrush="#E2DBD4" BorderThickness="0,0,1,0"><TextBlock Text="Wednesday" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/></Border><Border BorderBrush="#E2DBD4" BorderThickness="0,0,1,0"><TextBlock Text="Thursday" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/></Border><Border BorderBrush="#E2DBD4" BorderThickness="0,0,1,0"><TextBlock Text="Friday" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/></Border><TextBlock Text="Saturday" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/></UniformGrid></Border>
        <Border Grid.Row="2" Classes="card" Padding="0" ClipToBounds="True">
          <ItemsControl ItemsSource="{Binding CalendarDays}">
            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="7" Rows="6"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:CalendarDayViewModel">
              <Border BorderBrush="#EEE8E2" BorderThickness="0.5" Padding="8">
                <Grid RowDefinitions="Auto,*"><Border Width="31" Height="31" CornerRadius="16" HorizontalAlignment="Left" Background="{Binding DayBackground}" Opacity="{Binding Opacity}"><TextBlock Text="{Binding DayNumber}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding DayForeground}" FontWeight="SemiBold"/></Border>
                  <ItemsControl Grid.Row="1" ItemsSource="{Binding Events}" Margin="0,3,0,0"><ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:EventChipViewModel"><Border Classes="event" Background="{Binding Background}" Margin="0,2"><TextBlock Text="{Binding Title}" Foreground="{Binding Foreground}" FontSize="11" TextTrimming="CharacterEllipsis"/></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                </Grid>
              </Border>
            </DataTemplate></ItemsControl.ItemTemplate>
          </ItemsControl>
        </Border>
      </Grid>

      <!-- AGENDA -->
      <Grid IsVisible="{Binding IsAgenda}" RowDefinitions="72,*" ColumnDefinitions="2*,1*" ColumnSpacing="16">
        <TextBlock Classes="heading" Text="Agenda"/><Border Grid.Row="1" Classes="card"><Grid RowDefinitions="Auto,*,Auto"><TextBlock Classes="section" Text="{Binding TodayLongDate}"/><ItemsControl Grid.Row="1" ItemsSource="{Binding AgendaItems}" Margin="0,18,0,0"><ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:AgendaItemViewModel"><Border Classes="event" Background="{Binding Background}" Margin="0,5" Padding="14"><Grid ColumnDefinitions="84,50,*"><TextBlock Text="{Binding Time}" FontWeight="Bold" VerticalAlignment="Center"/><Border Grid.Column="1" Width="38" Height="38" CornerRadius="19" Background="#092354"><TextBlock Text="{Binding Initials}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><StackPanel Grid.Column="2"><TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold"/><TextBlock Text="{Binding Location}" Classes="muted"/></StackPanel></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><TextBlock Grid.Row="2" Text="No calendar events are available. Connect Google Calendar or add a calendar source in Settings." Classes="muted" TextWrapping="Wrap" Margin="0,20"/></Grid></Border>
        <StackPanel Grid.Column="1" Grid.RowSpan="2" Margin="0,72,0,0" Spacing="14"><Border Classes="card"><StackPanel><TextBlock Classes="section" Text="Coming up next"/><TextBlock Text="Nothing scheduled" FontSize="20" Margin="0,16,0,4"/><TextBlock Text="Waiting for calendar synchronization" Classes="muted"/></StackPanel></Border><Border Classes="card"><StackPanel><TextBlock Classes="section" Text="Day summary"/><TextBlock Text="0 appointments" FontSize="20" Margin="0,14,0,4"/><TextBlock Text="No conflicts" Classes="muted"/></StackPanel></Border></StackPanel>
      </Grid>

      <!-- FAMILY -->
      <Grid IsVisible="{Binding IsFamily}" RowDefinitions="72,*" ColumnDefinitions="1.25*,1*" ColumnSpacing="16"><TextBlock Classes="heading" Text="Family"/><ScrollViewer Grid.Row="1"><ItemsControl ItemsSource="{Binding People}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:PersonCardViewModel"><Button Command="{Binding $parent[Window].DataContext.SelectPersonCommand}" CommandParameter="{Binding}" Background="Transparent" Padding="0" Margin="0,0,14,14"><Border Classes="card" Width="250" MinHeight="175"><StackPanel><Border Width="58" Height="58" CornerRadius="29" Background="{Binding Color}" HorizontalAlignment="Left"><TextBlock Text="{Binding Initials}" Foreground="White" FontSize="21" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Text="{Binding Name}" FontSize="23" FontWeight="Bold" Foreground="#092354" Margin="0,10,0,3"/><TextBlock Text="{Binding Aliases}" Classes="muted" TextWrapping="Wrap"/><TextBlock Text="Tap to view events" Foreground="#FF5C60" Margin="0,10,0,0"/></StackPanel></Border></Button></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer><Border Grid.Row="1" Grid.Column="1" Classes="card"><Grid RowDefinitions="Auto,*,Auto"><TextBlock Classes="section" Text="{Binding SelectedPersonName}"/><ItemsControl Grid.Row="1" ItemsSource="{Binding SelectedPersonEvents}" Margin="0,14,0,0"><ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:AgendaItemViewModel"><Border Classes="event" Background="{Binding Background}"><StackPanel><TextBlock Text="{Binding Title}" FontWeight="Bold"/><TextBlock Text="{Binding Time}"/></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><TextBlock Grid.Row="2" Text="No synchronized events for this person." Classes="muted" Margin="0,14,0,0"/></Grid></Border></Grid>

      <!-- WEATHER: complete seven-day detail is fixed in the right-hand corner -->
      <Grid IsVisible="{Binding IsWeather}" ColumnDefinitions="1.15*,1*" RowDefinitions="1.05*,1*" ColumnSpacing="14" RowSpacing="14">
        <Border Classes="card" Padding="0" ClipToBounds="True" Background="#8FD7F4"><Grid><Border VerticalAlignment="Bottom" Height="88" Background="#49AEE2" Opacity=".75"/><Grid Margin="26,22" RowDefinitions="Auto,*,Auto"><Grid ColumnDefinitions="*,Auto"><TextBlock Text="{Binding CurrentLocationName}" FontSize="36" FontWeight="Bold" Foreground="#08285D" TextTrimming="CharacterEllipsis"/><TextBlock Grid.Column="1" Text="{Binding WeatherStatus}" FontSize="11"/></Grid><Grid Grid.Row="1" ColumnDefinitions="*,Auto"><StackPanel VerticalAlignment="Center"><TextBlock Text="{Binding CurrentTemperatureText}" FontSize="82" FontWeight="Bold" Foreground="#08285D"/><TextBlock Text="{Binding CurrentCondition}" FontSize="28" FontWeight="Bold" Foreground="#08285D"/><TextBlock Text="{Binding FeelsLikeText}" FontSize="18"/></StackPanel><TextBlock Grid.Column="1" Text="{Binding CurrentIcon}" FontSize="108" Foreground="#FFB000" VerticalAlignment="Center"/></Grid><TextBlock Grid.Row="2" Text="Live seven-day forecast • Open-Meteo • cached for offline use" Foreground="White" FontSize="16"/></Grid></Grid></Border>
        <Border Grid.Column="1" Grid.RowSpan="2" Classes="card"><Grid RowDefinitions="Auto,*"><TextBlock Classes="section" Text="7-day forecast"/><ScrollViewer Grid.Row="1"><ItemsControl ItemsSource="{Binding ForecastDays}" Margin="0,12,0,0"><ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:ForecastDayViewModel"><Border BorderBrush="#EEE8E2" BorderThickness="0,0,0,1" Padding="4,10"><Grid ColumnDefinitions="52,34,*,72" RowDefinitions="Auto,Auto"><StackPanel><TextBlock Text="{Binding Day}" FontWeight="Bold"/><TextBlock Text="{Binding Date}" FontSize="11" Classes="muted"/></StackPanel><TextBlock Grid.Column="1" Text="{Binding Icon}" FontSize="23" VerticalAlignment="Center"/><StackPanel Grid.Column="2"><TextBlock Text="{Binding Condition}" FontWeight="SemiBold"/><TextBlock Text="{Binding PrecipitationProbability, StringFormat='Rain {0}%'}" Classes="muted" FontSize="11"/><TextBlock Text="{Binding PrecipitationInches, StringFormat='Precip {0:0.00} in'}" Classes="muted" FontSize="11"/></StackPanel><StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right"><TextBlock Text="{Binding High, StringFormat='{}{0}°'}" FontSize="24"/><TextBlock Text="{Binding Low, StringFormat=' / {0}°'}" Classes="muted" VerticalAlignment="Center"/></StackPanel><StackPanel Grid.Row="1" Grid.ColumnSpan="4" Orientation="Horizontal" Spacing="12" Margin="0,4,0,0"><TextBlock Text="{Binding MaxWindMph, StringFormat='Wind {0} mph'}" FontSize="10" Classes="muted"/><TextBlock Text="{Binding GustMph, StringFormat='Gust {0}'}" FontSize="10" Classes="muted"/><TextBlock Text="{Binding Humidity, StringFormat='Humidity {0}%'}" FontSize="10" Classes="muted"/><TextBlock Text="{Binding UvIndex, StringFormat='UV {0}'}" FontSize="10" Classes="muted"/><TextBlock Text="{Binding Sunrise, StringFormat='↑{0}'}" FontSize="10" Classes="muted"/><TextBlock Text="{Binding Sunset, StringFormat='↓{0}'}" FontSize="10" Classes="muted"/></StackPanel></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer></Grid></Border>
        <Border Grid.Row="1" Classes="card"><Grid ColumnDefinitions="*,*,*" RowDefinitions="*,*" ColumnSpacing="10" RowSpacing="10"><Border Classes="metric" Background="#E8F6DA"><StackPanel><TextBlock Text="☁ Cloud cover"/><TextBlock Text="{Binding CloudCoverText}" FontSize="35"/><TextBlock Text="Open-Meteo current"/></StackPanel></Border><Border Grid.Column="1" Classes="metric" Background="#FFF2C8"><StackPanel><TextBlock Text="☀ UV index"/><TextBlock Text="{Binding UvText}" FontSize="35"/><TextBlock Text="Daily maximum"/></StackPanel></Border><Border Grid.Column="2" Classes="metric" Background="#DDEEFF"><StackPanel><TextBlock Text="≋ Wind"/><TextBlock Text="{Binding WindText}" FontSize="30"/><TextBlock Text="{Binding GustText}"/></StackPanel></Border><Border Grid.Row="1" Classes="metric" Background="#DDF7F5"><StackPanel><TextBlock Text="💧 Humidity"/><TextBlock Text="{Binding HumidityText}" FontSize="35"/><TextBlock Text="{Binding DewPointText, StringFormat='Dew point {0}'}"/></StackPanel></Border><Border Grid.Row="1" Grid.Column="1" Classes="metric" Background="#EFE5FF"><StackPanel><TextBlock Text="◉ Visibility"/><TextBlock Text="{Binding VisibilityText}" FontSize="35"/><TextBlock Text="{Binding PressureText, StringFormat='Pressure {0}'}"/><TextBlock Text="{Binding PrecipitationText, StringFormat='Precip {0}'}"/></StackPanel></Border><Border Grid.Row="1" Grid.Column="2" Classes="metric" Background="#FFE6E7"><StackPanel><TextBlock Text="☀ Sun"/><TextBlock Text="{Binding SunriseText}" FontSize="20"/><TextBlock Text="{Binding SunsetText}" FontSize="20"/></StackPanel></Border></Grid></Border>
      </Grid>

      <!-- CLASS BLOCK: each child's position in the school day, advancing live -->
      <Grid IsVisible="{Binding IsClassBlock}" RowDefinitions="72,Auto,*" ColumnSpacing="16">
        <Grid ColumnDefinitions="*,Auto"><TextBlock Classes="heading" Text="Class Block"/><TextBlock Grid.Column="1" Text="{Binding ClassBlockHeader}" FontSize="19" FontWeight="SemiBold" Foreground="#FF5C60" VerticalAlignment="Center"/></Grid>
        <ItemsControl Grid.Row="1" ItemsSource="{Binding StudentBlocks}" Margin="0,0,0,14">
          <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:StudentBlockViewModel">
            <Border Classes="card" Margin="0,0,12,12" Padding="18">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                <Border Width="56" Height="56" CornerRadius="28" Background="{Binding Color}" VerticalAlignment="Top"><TextBlock Text="{Binding Initials}" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                <StackPanel Grid.Column="1" Spacing="3">
                  <Grid ColumnDefinitions="*,Auto"><TextBlock Text="{Binding Name}" FontSize="23" FontWeight="Bold" Foreground="#092354"/><Border Grid.Column="1" Background="#F1EDE8" CornerRadius="8" Padding="8,3" VerticalAlignment="Center"><TextBlock Text="{Binding LevelText}" FontSize="11" Classes="muted"/></Border></Grid>
                  <TextBlock Text="{Binding Headline}" FontSize="20" FontWeight="SemiBold" Foreground="{Binding Color}" TextTrimming="CharacterEllipsis"/>
                  <TextBlock Text="{Binding Detail}" Classes="muted" FontSize="13"/>
                  <!-- Progress through the current block -->
                  <Border Height="12" CornerRadius="6" Background="#EFEAE4" Margin="0,6,0,0" HorizontalAlignment="Left" Width="300" IsVisible="{Binding IsInSchool}">
                    <Border CornerRadius="6" Background="{Binding Color}" Width="{Binding BlockBarWidth}" HorizontalAlignment="Left"/>
                  </Border>
                  <!-- Progress through the whole school day -->
                  <TextBlock Text="Day progress" FontSize="10" Classes="muted" Margin="0,6,0,2" IsVisible="{Binding IsInSchool}"/>
                  <Border Height="7" CornerRadius="4" Background="#EFEAE4" HorizontalAlignment="Left" Width="300" IsVisible="{Binding IsInSchool}">
                    <Border CornerRadius="4" Background="#092354" Width="{Binding DayBarWidth}" HorizontalAlignment="Left"/>
                  </Border>
                  <TextBlock Text="{Binding NextUp}" FontSize="12" Classes="muted" Margin="0,6,0,0"/>
                  <TextBlock Text="{Binding SchoolName}" FontSize="10" Classes="muted" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate></ItemsControl.ItemTemplate>
        </ItemsControl>
        <Border Grid.Row="2" Classes="card"><Grid RowDefinitions="Auto,*,Auto">
          <TextBlock Classes="section" Text="Today's blocks"/>
          <ScrollViewer Grid.Row="1"><ItemsControl ItemsSource="{Binding ScheduleRows}" Margin="0,10,0,0"><ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:ScheduleRowViewModel">
            <Border CornerRadius="10" Padding="12,8" Margin="0,3" Background="{Binding RowBackground}" Opacity="{Binding RowOpacity}">
              <Grid ColumnDefinitions="88,120,*"><TextBlock Text="{Binding Level}" FontSize="11" Classes="muted" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="{Binding TimeText}" FontWeight="SemiBold" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding Name}" VerticalAlignment="Center"/></Grid>
            </Border>
          </DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer>
          <TextBlock Grid.Row="2" Text="{Binding ClassBlockSourceNote}" Classes="muted" FontSize="11" Margin="0,10,0,0"/>
        </Grid></Border>
      </Grid>

      <!-- NEWS -->
      <Grid IsVisible="{Binding IsNews}" RowDefinitions="72,Auto,*">
        <Grid ColumnDefinitions="*,Auto,Auto"><TextBlock Classes="heading" Text="News"/><TextBlock Grid.Column="1" Text="{Binding NewsStatus}" Classes="muted" VerticalAlignment="Center" Margin="0,0,12,0"/><Button Grid.Column="2" Classes="nav top" Content="Refresh" Command="{Binding RefreshNewsCommand}"/></Grid>
        <Border Grid.Row="1" Background="#EAF2FB" CornerRadius="12" Padding="14,10" Margin="0,0,0,12">
          <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#1E3A5F" Text="Headlines are pulled directly from each outlet's public RSS feed and shown in the outlet's own words. FamilyHub does not write, edit, verify, or endorse any of it. Perspective labels are a rough guide drawn from commonly cited media-bias assessments, which are themselves contested — treat them as a prompt to read widely, not as a rating. Always open the source link for the full article."/>
        </Border>
        <ScrollViewer Grid.Row="2"><ItemsControl ItemsSource="{Binding NewsStories}">
          <ItemsControl.ItemTemplate><DataTemplate x:DataType="inf:NewsStory">
            <Border Classes="card" Margin="0,0,0,10" Padding="16">
              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <Border Background="{Binding SourceColor}" CornerRadius="7" Padding="9,3"><TextBlock Text="{Binding SourceName}" Foreground="White" FontSize="11" FontWeight="Bold"/></Border>
                  <TextBlock Grid.Column="1" Text="{Binding SourceLean}" FontSize="11" Classes="muted" VerticalAlignment="Center" Margin="9,0"/>
                  <TextBlock Grid.Column="2" Text="{Binding PublishedText}" FontSize="11" Classes="muted" VerticalAlignment="Center"/>
                </Grid>
                <TextBlock Text="{Binding Title}" FontSize="19" FontWeight="Bold" Foreground="#092354" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" FontSize="13"/>
                <TextBlock Text="{Binding Link}" FontSize="11" Foreground="#2563EB" TextTrimming="CharacterEllipsis"/>
                <Border Background="#F7F4F0" CornerRadius="8" Padding="10,7">
                  <TextBlock Text="{Binding Disclaimer}" FontSize="10" Classes="muted" TextWrapping="Wrap"/>
                </Border>
              </StackPanel>
            </Border>
          </DataTemplate></ItemsControl.ItemTemplate>
        </ItemsControl></ScrollViewer>
      </Grid>

      <!-- SETTINGS -->
      <Grid IsVisible="{Binding IsSettings}" RowDefinitions="72,*"><TextBlock Classes="heading" Text="Settings"/><ScrollViewer Grid.Row="1"><Grid ColumnDefinitions="1*,1*" ColumnSpacing="16"><Border Classes="card"><StackPanel Spacing="12"><TextBlock Classes="section" Text="Weather location"/><TextBlock Text="Choose the saved home location used by the Windows/Pi dashboard. It will never be replaced automatically." Classes="muted" TextWrapping="Wrap"/><TextBlock Text="Current location" FontWeight="Bold"/><TextBlock Text="{Binding CurrentLocationName}" FontSize="22"/><TextBlock Text="ZIP code, city and state, or coordinates" FontWeight="Bold"/><TextBox Text="{Binding WeatherLocationQuery}" PlaceholderText="27330  •  Sanford, NC  •  35.4799,-79.1803"/><StackPanel Orientation="Horizontal" Spacing="10"><Button Classes="coral top" Content="Save location" Command="{Binding ApplyWeatherLocationCommand}"/><Button Classes="nav top" Content="Refresh" Command="{Binding RefreshWeatherNowCommand}"/></StackPanel><TextBlock Text="{Binding WeatherStatus}" Classes="muted" TextWrapping="Wrap"/></StackPanel></Border><Border Grid.Column="1" Classes="card"><StackPanel Spacing="12"><TextBlock Classes="section" Text="Display"/><TextBlock Text="Automatic theme" FontWeight="Bold"/><TextBlock Text="Light mode: 6:00 AM – 6:00 PM"/><TextBlock Text="Dark mode: 6:00 PM – 6:00 AM"/><TextBlock Text="Screen rotation and Google Calendar controls are available from the Android companion app." Classes="muted" TextWrapping="Wrap" Margin="0,12,0,0"/><TextBlock Classes="section" Text="Calendars" Margin="0,20,0,0"/><TextBlock Text="US federal holidays and common observances are built in and need no setup." Classes="muted" TextWrapping="Wrap"/><TextBlock Text="{Binding SchoolCalendarStatusText}" FontWeight="Bold" TextWrapping="Wrap"/><Border Background="#FFF1D6" CornerRadius="10" Padding="12,8" IsVisible="{Binding HasPendingSchoolCalendars}"><TextBlock Text="A school calendar is held back until its dates are checked against the district's official calendar. Edit school-calendars.json and set its status to Reviewed." Foreground="#8A5A00" TextWrapping="Wrap"/></Border></StackPanel></Border></Grid></ScrollViewer></Grid>

      <!-- DAILY AND WEEKLY -->
      <Grid IsVisible="{Binding IsDaily}" RowDefinitions="72,*" ColumnDefinitions="2*,1*" ColumnSpacing="14"><TextBlock Classes="heading" Text="Today"/><Border Grid.Row="1" Classes="card"><Grid RowDefinitions="Auto,Auto,*,Auto"><TextBlock Classes="section" Text="{Binding TodayLongDate}"/><Border Grid.Row="1" Background="#FFF1D6" CornerRadius="10" Padding="12,8" Margin="0,10,0,0" IsVisible="{Binding HasTodayHoliday}"><TextBlock Text="{Binding TodayHolidayText}" FontWeight="SemiBold" Foreground="#8A5A00" TextWrapping="Wrap"/></Border><ItemsControl Grid.Row="2" ItemsSource="{Binding AgendaItems}" Margin="0,18,0,0"><ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:AgendaItemViewModel"><Border Classes="event" Background="{Binding Background}" Margin="0,5" Padding="14"><Grid ColumnDefinitions="90,*"><TextBlock Text="{Binding Time}" FontWeight="Bold"/><StackPanel Grid.Column="1"><TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold"/><TextBlock Text="{Binding Location}" Classes="muted"/></StackPanel></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><TextBlock Grid.Row="3" Text="No events to display. Connect a calendar source in Settings." Classes="muted" Margin="0,20"/></Grid></Border><StackPanel Grid.Column="1" Grid.RowSpan="2" Margin="0,72,0,0" Spacing="14"><Border Classes="card"><StackPanel><TextBlock Classes="section" Text="Coming up next"/><TextBlock Text="Nothing scheduled" FontSize="20" Margin="0,16,0,4"/><TextBlock Text="Waiting for calendar synchronization" Classes="muted"/></StackPanel></Border><Border Classes="card"><TextBlock Text="Tomorrow • no synchronized events"/></Border></StackPanel></Grid>
      <Grid IsVisible="{Binding IsWeekly}" RowDefinitions="72,*"><TextBlock Classes="heading" Text="{Binding WeekTitle}"/><Border Grid.Row="1" Classes="card" Padding="0"><Grid ColumnDefinitions="*,*,*,*,*,*,*"><Border BorderBrush="#E2DBD4" BorderThickness="0,0,1,0"><StackPanel><TextBlock Text="Sunday" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,15"/><Border BorderBrush="#EEE8E2" BorderThickness="0,1,0,0" MinHeight="520"/></StackPanel></Border><Border Grid.Column="1" BorderBrush="#E2DBD4" BorderThickness="0,0,1,0"><StackPanel><TextBlock Text="Monday" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,15"/><Border BorderBrush="#EEE8E2" BorderThickness="0,1,0,0" MinHeight="520"/></StackPanel></Border><Border Grid.Column="2" BorderBrush="#E2DBD4" BorderThickness="0,0,1,0"><StackPanel><TextBlock Text="Tuesday" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,15"/><Border BorderBrush="#EEE8E2" BorderThickness="0,1,0,0" MinHeight="520"/></StackPanel></Border><Border Grid.Column="3" BorderBrush="#E2DBD4" BorderThickness="0,0,1,0"><StackPanel><TextBlock Text="Wednesday" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,15"/><Border BorderBrush="#EEE8E2" BorderThickness="0,1,0,0" MinHeight="520"/></StackPanel></Border><Border Grid.Column="4" BorderBrush="#E2DBD4" BorderThickness="0,0,1,0"><StackPanel><TextBlock Text="Thursday" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,15"/><Border BorderBrush="#EEE8E2" BorderThickness="0,1,0,0" MinHeight="520"/></StackPanel></Border><Border Grid.Column="5" BorderBrush="#E2DBD4" BorderThickness="0,0,1,0"><StackPanel><TextBlock Text="Friday" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,15"/><Border BorderBrush="#EEE8E2" BorderThickness="0,1,0,0" MinHeight="520"/></StackPanel></Border><StackPanel Grid.Column="6"><TextBlock Text="Saturday" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,15"/><Border BorderBrush="#EEE8E2" BorderThickness="0,1,0,0" MinHeight="520"/></StackPanel></Grid></Border></Grid>
    </Panel>

    <!-- Search results and filter controls -->
    <Border Grid.Column="1" Grid.Row="1" Classes="card" Width="430" MaxHeight="430" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,162,0" ZIndex="20" IsVisible="{Binding HasSearchResults}">
      <Grid RowDefinitions="Auto,*"><TextBlock Classes="section" Text="Search results"/><ScrollViewer Grid.Row="1"><ItemsControl ItemsSource="{Binding SearchResults}" Margin="0,10,0,0"><ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:SearchResultViewModel"><Button Command="{Binding $parent[Window].DataContext.OpenSearchResultCommand}" CommandParameter="{Binding}" Background="Transparent" HorizontalContentAlignment="Stretch" Padding="8"><Grid ColumnDefinitions="90,*"><TextBlock Text="{Binding Kind}" Foreground="#FF5C60" FontWeight="Bold"/><StackPanel Grid.Column="1"><TextBlock Text="{Binding Title}" FontWeight="Bold"/><TextBlock Text="{Binding Subtitle}" Classes="muted" TextWrapping="Wrap"/></StackPanel></Grid></Button></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer></Grid>
    </Border>
    <Border Grid.Column="1" Grid.Row="1" Classes="card" Width="270" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,26,0" ZIndex="21" IsVisible="{Binding IsFilterPanelOpen}">
      <StackPanel Spacing="10"><Grid ColumnDefinitions="*,Auto"><TextBlock Classes="section" Text="Search filters"/><Button Grid.Column="1" Content="×" Command="{Binding ToggleFiltersCommand}"/></Grid><CheckBox Content="Family members and aliases" IsChecked="{Binding SearchPeople}"/><CheckBox Content="Events and locations" IsChecked="{Binding SearchEvents}"/><CheckBox Content="Appointment types" IsChecked="{Binding SearchAppointments}"/><TextBlock Text="The former diamond button is now a labeled filter control." Classes="muted" TextWrapping="Wrap"/></StackPanel>
    </Border>

    <!-- Functional local event editor -->
    <Border Grid.ColumnSpan="2" Grid.RowSpan="2" Background="#9909182F" ZIndex="50" IsVisible="{Binding IsEventEditorOpen}">
      <Border Classes="card" Width="560" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="28"><StackPanel Spacing="12"><Grid ColumnDefinitions="*,Auto"><TextBlock Classes="heading" FontSize="32" Text="New event"/><Button Grid.Column="1" Content="×" Command="{Binding CloseEventEditorCommand}"/></Grid><TextBlock Text="Title" FontWeight="Bold"/><TextBox Text="{Binding NewEventTitle}" PlaceholderText="Dentist appointment"/><Grid ColumnDefinitions="*,*" ColumnSpacing="12"><StackPanel><TextBlock Text="Start" FontWeight="Bold"/><TextBox Text="{Binding NewEventStart}"/></StackPanel><StackPanel Grid.Column="1"><TextBlock Text="End" FontWeight="Bold"/><TextBox Text="{Binding NewEventEnd}"/></StackPanel></Grid><TextBlock Text="Family member" FontWeight="Bold"/><TextBox Text="{Binding NewEventPerson}" PlaceholderText="Dad, Xander, Jada…"/><TextBlock Text="Appointment type" FontWeight="Bold"/><TextBox Text="{Binding NewEventCategory}" PlaceholderText="Dentist, school, therapy…"/><TextBlock Text="Location" FontWeight="Bold"/><TextBox Text="{Binding NewEventLocation}"/><TextBlock Text="{Binding EventEditorError}" Foreground="#C62828" TextWrapping="Wrap"/><StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10"><Button Content="Cancel" Command="{Binding CloseEventEditorCommand}"/><Button Classes="coral" Content="Save event" Command="{Binding SaveNewEventCommand}"/></StackPanel></StackPanel></Border>
    </Border>
  </Grid>
</Window>
