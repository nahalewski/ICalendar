<Application xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="FamilyHub.App.App">
  <Application.Resources>
    <ResourceDictionary><ResourceDictionary.ThemeDictionaries>
      <ResourceDictionary x:Key="Light"><SolidColorBrush x:Key="AppBackground">#FCF9F5</SolidColorBrush><SolidColorBrush x:Key="SurfaceBrush">#FFFFFF</SolidColorBrush><SolidColorBrush x:Key="SidebarBrush">#FFFCF8</SolidColorBrush><SolidColorBrush x:Key="PrimaryTextBrush">#092354</SolidColorBrush><SolidColorBrush x:Key="MutedTextBrush">#667085</SolidColorBrush></ResourceDictionary>
      <ResourceDictionary x:Key="Dark"><SolidColorBrush x:Key="AppBackground">#101521</SolidColorBrush><SolidColorBrush x:Key="SurfaceBrush">#1A2232</SolidColorBrush><SolidColorBrush x:Key="SidebarBrush">#151C2A</SolidColorBrush><SolidColorBrush x:Key="PrimaryTextBrush">#F5F7FF</SolidColorBrush><SolidColorBrush x:Key="MutedTextBrush">#B5BED0</SolidColorBrush></ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries></ResourceDictionary>
  </Application.Resources>
  <Application.Styles>
    <FluentTheme />
    <Style Selector="Button"><Setter Property="MinHeight" Value="46"/><Setter Property="CornerRadius" Value="15"/><Setter Property="FontSize" Value="15"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
    <Style Selector="Button.nav"><Setter Property="MinWidth" Value="46"/><Setter Property="MinHeight" Value="46"/><Setter Property="CornerRadius" Value="15"/><Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/><Setter Property="BorderBrush" Value="#E8E2DC"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/><Setter Property="FontSize" Value="21"/></Style>
    <Style Selector="Button.coral"><Setter Property="Background" Value="#FF5C60"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="22,10"/></Style>
    <Style Selector="Button.top"><Setter Property="Height" Value="46"/><Setter Property="MinWidth" Value="54"/><Setter Property="CornerRadius" Value="14"/><Setter Property="Padding" Value="14,8"/><Setter Property="FontSize" Value="14"/></Style>
    <Style Selector="Button.side"><Setter Property="HorizontalContentAlignment" Value="Left"/><Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/><Setter Property="Padding" Value="16,10"/><Setter Property="Margin" Value="0,2"/><Setter Property="FontWeight" Value="Normal"/></Style>
    <Style Selector="Button.side.active"><Setter Property="Background" Value="#FFE7E1"/><Setter Property="Foreground" Value="#F04449"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
    <Style Selector="Border.card"><Setter Property="CornerRadius" Value="20"/><Setter Property="Padding" Value="20"/><Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/><Setter Property="BorderBrush" Value="#ECE7E1"/><Setter Property="BorderThickness" Value="1"/><Setter Property="BoxShadow" Value="0 8 24 0 #14092B52"/></Style>
    <Style Selector="Border.metric"><Setter Property="CornerRadius" Value="20"/><Setter Property="Padding" Value="18"/><Setter Property="MinHeight" Value="125"/></Style>
    <Style Selector="Border.event"><Setter Property="CornerRadius" Value="8"/><Setter Property="Padding" Value="8,5"/><Setter Property="Margin" Value="5,2"/></Style>
    <Style Selector="TextBlock.heading"><Setter Property="FontSize" Value="47"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/></Style>
    <Style Selector="TextBlock.section"><Setter Property="FontSize" Value="22"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/></Style>
    <Style Selector="TextBlock.muted"><Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/></Style>
  </Application.Styles>
</Application>
