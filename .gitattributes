# Normalise line endings so scripts work on the platform they run on.
* text=auto

# Shell scripts MUST be LF. A CRLF shebang makes Linux fail with
# "bad interpreter: /usr/bin/env bash^M", which is exactly how the Pi install
# would break after being authored on Windows.
*.sh text eol=lf

# PowerShell is happiest with CRLF on Windows.
*.ps1 text eol=crlf

# systemd units and JSON data files are read on Linux too.
*.service text eol=lf
*.timer   text eol=lf

# Never touch binaries.
*.png binary
*.jpg binary
*.pdf binary
*.keystore binary
*.jks binary
